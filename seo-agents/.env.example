# Copy to .env and fill in values (never commit .env)

# ── Required for full agent runs (Phase 2+) ──────────────────────────
ANTHROPIC_API_KEY=

# ── Required for DataCollector steps 4–6 (Phase 1 Week 2) ───────────
GOOGLE_PSI_API_KEY=
GSC_SERVICE_ACCOUNT_JSON=./secrets/gsc-service-account.json
SERPAPI_KEY=

# ── Recommended SerpAPI fallback ─────────────────────────────────────
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ── Site / paths ─────────────────────────────────────────────────────
SEO_SITE_URL=https://jedmee.com
SEO_REPO_ROOT=..

# ── Optional ─────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
PSI_CACHE_TTL_HOURS=6
SERPAPI_MONTHLY_CAP=100
