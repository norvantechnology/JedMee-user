# Copy to .env and fill in values (never commit .env)

# PageSpeed Insights
GOOGLE_PSI_API_KEY=

# Search Console — OAuth (recommended)
# Run once: python scripts/authorize_gsc_oauth.py
GSC_AUTH_MODE=oauth
GSC_PROPERTY_URL=https://jedmee.com/
GSC_OAUTH_CLIENT_JSON=./secrets/gsc-oauth-client.json
GSC_OAUTH_TOKEN_JSON=./secrets/gsc-oauth-token.json

# Alternative: service account (if you can add robot email in GSC Users)
# GSC_AUTH_MODE=service_account
# GSC_SERVICE_ACCOUNT_JSON=./secrets/gsc-service-account.json

# SERP / competitors
SERPAPI_KEY=

# Site
SEO_SITE_URL=https://jedmee.com
SEO_REPO_ROOT=..

# Optional LLM for ContentAgent + AI Visibility (Gemini free tier)
# GEMINI_API_KEY=
# LLM_PROVIDER=auto

# Optional Slack summary after weekly audit
# SLACK_WEBHOOK_URL=
