  "dependencies": {},
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/s3-request-presigner": "^3.1040.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.15.2",
    "pg": "^8.16.3",
    "xlsx": "^0.18.5"
  }
}
