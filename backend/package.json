{
  "name": "medico-user-backend",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "STAGE=local PORT=4000 node local-server.js",
    "dev:dev": "STAGE=dev PORT=4000 node local-server.js",
    "dev:prod": "STAGE=prod PORT=4000 node local-server.js",
    "layer:install": "cd lib/nodejs-light/nodejs && npm install"
  },
  "engines": {
    "node": ">=22"
  },
